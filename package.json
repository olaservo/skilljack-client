{
  "name": "mcp-skilljack-client",
  "version": "0.3.0",
  "description": "A full-capability MCP client demonstrating all advanced protocol features",
  "type": "module",
  "main": ".vite/build/main.cjs",
  "types": "dist/index.d.ts",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc && npm run build:chat",
    "build:chat": "vite build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:chat": "vite",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "electron-forge start",
    "electron:build": "electron-forge make",
    "electron:package": "electron-forge package",
    "electron:publish": "electron-forge publish",
    "pack-mcpb": "node scripts/pack-mcpb.js"
  },
  "config": {
    "forge": "./forge.config.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "client",
    "reference-implementation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0",
    "@ai-sdk/anthropic": "^4.0.8",
    "@ai-sdk/openai": "^4.0.7",
    "@anthropic-ai/sdk": "^0.110.0",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-toggle": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@skilljack/internal-server-config": "workspace:*",
    "@skilljack/internal-tool-manager": "workspace:*",
    "@skilljack/mcp-server-manager": "workspace:*",
    "ai": "^7.0.15",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "fflate": "^0.8.3",
    "node-forge": "^1.3.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "eslint": "^10.7.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "tar": "^7.5.16",
    "tmp": "^0.2.6"
  }
}
